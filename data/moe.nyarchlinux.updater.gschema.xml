<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="nyarchupdater">
	<schema id="moe.nyarchlinux.updater" path="/moe/nyarchlinux/updater/">
        <key name="first-start" type="b">
            <default>true</default>
        </key>
        <key name="aur-updates-enabled" type="b">
            <default>true</default>
        </key>
        <key name="aur-helper" type="s">
            <default>"auto"</default>
            <description>The AUR helper Updater will use. Must be one of the supported choices.</description>
            <summary>AUR Helper</summary>
            <choices>
                <choice value="auto" />
                <choice value="paru" />
                <choice value="yay" />
                <choice value="pikaur" />
                <choice value="trizen" />
            </choices>
        </key>
        <key name="system-update-command" type="s">
            <default>"sudo pacman -Syu"</default>
            <description>The command used to run system updates.</description>
            <summary>System Update Command</summary>
        </key>
  </schema>
</schemalist>
